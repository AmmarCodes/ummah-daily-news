# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
SESSION_STRING=

# Telegram Channel IDs, can be handles for public channels or 
#   numeric -100.. for private ones
TELEGRAM_CHANNEL_ID_ENGLISH=
TELEGRAM_CHANNEL_ID_ARABIC=

# AI Provider Configuration
# Choose one provider or use OpenRouter for unified access to multiple models
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=openrouter/anthropic/claude-3-5-sonnet-20241022
# Alternative: AI_MODEL=openai:gpt-4.1-2025-04-14
# Alternative: AI_MODEL=anthropic:claude-3-5-sonnet-20241022

# GitHub Publishing (for website integration)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Cloudflare Worker Configuration
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Deployment Configuration (optional)
SIMULATE_WEBSITE_PUBLISH=false
ALERT_EMAIL=

# Local Development/Debugging (optional)
DEDUPE_OUTPUT_FOLDER=
