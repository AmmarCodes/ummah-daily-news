{
  "name": "sy-daily",
  "version": "1.0.0",
  "type": "module",
  "description": "A bot that collects news about Syria from a curated list of sources and posts daily summaries to Telegram",
  "scripts": {
    "start": "ts-node src/local/index.ts",
    "build": "rimraf dist && ts-node esbuild.config.ts",
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "predeploy": "npm run build",
    "deploy": "wrangler deploy",
    "telegram:register-webhook": "dotenv -e .env -- ts-node src/telegram-dev/registerTelegramWebhook.ts",
    "telegram:serve": "dotenv -e .env -- ts-node src/telegram-dev/server.ts",
    "ts-node": "ts-node",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.15",
    "@ai-sdk/openai": "^2.0.28",
    "@octokit/rest": "^22.0.0",
    "ai": "^5.0.40",
    "axios": "^1.12.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "grammy": "^1.38.2",
    "input": "^1.0.1",
    "linkedom": "^0.18.12",
    "lodash": "^4.17.21",
    "openai": "^5.20.0",
    "telegram": "^2.26.22",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@types/express": "^5.0.1",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.15.11",
    "@types/node-fetch": "^2.6.13",
    "@vitest/ui": "^3.2.4",
    "dotenv-cli": "^8.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^28.1.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.70.0"
  },
  "packageManager": "yarn@4.5.0"
}
